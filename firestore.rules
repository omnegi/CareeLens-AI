rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Validation blueprints (Anti-update-gap)
    function isValidAnalysis(data) {
      return data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.roleName is string && data.roleName.size() <= 200
          && data.atsScore is int && data.atsScore >= 0 && data.atsScore <= 100;
    }

    function isValidInterview(data) {
      return data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.roleName is string && data.roleName.size() <= 200
          && data.status is string && (data.status == 'in-progress' || data.status == 'completed' || data.status == 'aborted');
    }

    // Collection: analyses
    match /analyses/{analysisId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(analysisId) && incoming().userId == request.auth.uid && isValidAnalysis(incoming());
      allow update: if isSignedIn() && isValidId(analysisId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidAnalysis(incoming()) && (
        incoming().createdAt == existing().createdAt && incoming().id == existing().id
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Collection: interviews
    match /interviews/{interviewId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(interviewId) && incoming().userId == request.auth.uid && isValidInterview(incoming());
      allow update: if isSignedIn() && isValidId(interviewId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidInterview(incoming()) && (
        incoming().createdAt == existing().createdAt && incoming().id == existing().id
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
